# Flask configuration
FLASK_ENV=development
# Set FLASK_DEBUG=1 to enable debug mode. This also activates demo mode:
# a "Demo Group" (join code DEMO42) is auto-created on first sign-in.
FLASK_DEBUG=0

# Required: must be a long, random, unpredictable string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-random-string

# Database connection string.
# SQLite (zero configuration, good for local dev):
DATABASE_URL=sqlite:///app.db
# PostgreSQL (run `docker-compose up -d` first):
# DATABASE_URL=postgresql://horse3903:password123@localhost:5432/calendar_matcher

# Google OAuth credentials.
# Set these up at https://console.cloud.google.com/ (see README for steps).
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must match exactly what you registered as an Authorized redirect URI.
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/auth/callback

# Base URL used when generating shareable invite links.
APP_BASE_URL=http://127.0.0.1:5000

# Optional: email address that can access debug/admin endpoints in production.
# Leave blank if not using production debug access.
DEBUG_OWNER_EMAIL=

# Optional: runtime mode hint. Use "prod" to suppress extra logging.
APP_MODE=dev
